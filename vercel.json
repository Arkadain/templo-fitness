{
    "version": 2,
    "functions": {
        "app.py": {
            "runtime": "vercel-python@4.3.1",
            "includeFiles": "templates/**"
        }
    },
    "routes": [{
            "src": "/static/(.*)",
            "dest": "/static/$1"
        },
        {
            "src": "/(.*)",
            "dest": "app.py"
        }
    ]
}